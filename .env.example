# mom-cloud environment configuration
# Copy this file to .env and fill in your values

# === iCloud Credentials ===
ICLOUD_USERNAME=your_apple_id@icloud.com
ICLOUD_PASSWORD=your_app_specific_password

# === Azure Storage ===
AZURE_STORAGE_ACCOUNT_NAME=momcloudstore
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_STORAGE_CONTAINER=photos

# === Pipeline Settings ===
LOCAL_STAGING_DIR=/data/staging
PHOTO_ORGANIZE_FORMAT=%Y/%m  # Organize by year/month
DEDUP_STRATEGY=hash           # hash | filename | exif
LOG_LEVEL=INFO

# === Monitoring (optional) ===
GRAFANA_ADMIN_PASSWORD=changeme
ALERT_EMAIL=your_email@example.com
